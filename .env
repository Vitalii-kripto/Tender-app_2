API_KEY=AIzaSy...ВАШ_КЛЮЧ_ЗДЕСЬ...

# Настройки сервера (опционально)
HOST=0.0.0.0
PORT=8000

# Режим отладки для AI (логирование промптов и ответов в legal_ai.log)
