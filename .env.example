# .env.example
API_KEY=

# Использовать SOCKS5 прокси через SSH туннель для доступа к zakupki.gov.ru (если заблокировано)
# По умолчанию false. Если true, требуется настроенный SSH доступ в backend/services/eis_service.py
USE_PROXY=false

# AI Analysis Debug
LEGAL_AI_DEBUG=false

# AI Model Configuration
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_MODEL_BACKUP=gemini-3.1-flash-lite-preview
GEMINI_MODEL_GROUND=gemini-2.5-flash
GEMINI_MODEL_GROUND_BACKUP=gemini-2.5-flash-lite
